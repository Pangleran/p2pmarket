# ──────────────────────────────────────────────────────────────────────────────
# P2P Market — Environment Variables
# Salin file ini ke .env dan isi nilainya
# cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────

# ─── URL Aplikasi (WAJIB di VPS) ─────────────────────────────────────────────
# URL publik frontend
APP_URL=https://yourdomain.com
# URL publik API (subdomain) — dipakai backend untuk CORS & redirect
API_URL=https://api.yourdomain.com
# URL API untuk frontend (Vite env) — harus sama dengan API_URL
VITE_API_URL=https://api.yourdomain.com

# ─── Database PostgreSQL (WAJIB) ─────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/p2pmarket

# ─── Discord OAuth2 (WAJIB) ──────────────────────────────────────────────────
# Dapatkan dari: https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── Discord Bot Token (OPSIONAL) ────────────────────────────────────────────
# Dibutuhkan untuk fitur admin sync-usernames
# Dapatkan dari: https://discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=

# ─── Cloudflare Turnstile (WAJIB) ────────────────────────────────────────────
# Dapatkan dari: https://dash.cloudflare.com/ → Turnstile
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Port Server API ─────────────────────────────────────────────────────────
# Port Express backend — nginx akan proxy ke port ini
PORT=3001

# ─── Upload Storage ──────────────────────────────────────────────────────────
# Folder penyimpanan file upload (absolute path)
UPLOAD_DIR=/home/ubuntu/p2pmarket/uploads

# ─── Node Environment ────────────────────────────────────────────────────────
NODE_ENV=production
